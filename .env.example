SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL=#general
PROJECTS_DIR=/path/to/your/projects

# --- Logging ---
# INFO (default): lifecycle logs only (sessions, channel mapping, errors) —
#                 matches the daemon's pre-stream-json behaviour.
# DEBUG: also stream every Claude event (assistant text, thinking, tool_use,
#        tool_result) as it arrives — useful for debugging Flow-B runs.
LOG_LEVEL=INFO

# --- Live progress (Slack → Claude / Flow-B) ---
# Surfaces Claude's work in the Slack thread *as it happens* (reading files,
# running tools, thinking, streaming the answer) instead of only the final reply.
#
# SLACK_STREAM_MODE:
#   auto   (default) try Slack native token-streaming; fall back to chat.update
#          if the streaming API errors, so the channel is never left dead.
#   native force Slack native streaming (chat.startStream/appendStream/stopStream).
#   update edit a single placeholder message via chat.update (only needs chat:write).
#   off    legacy behaviour — post only the final answer, no live feed.
SLACK_STREAM_MODE=auto
# SLACK_STREAM_VERBOSITY: rich (thinking + tool-result snippets) | normal (actions
# only) | quiet (high-level status only). Note: rich streams more detail into the
# (possibly shared) channel — tool targets and short result snippets, never secrets.
SLACK_STREAM_VERBOSITY=rich
# SLACK_STREAM_STATUS: also drive Slack's native animated "thinking…" indicator
# via assistant.threads.setStatus. Best inside the Assistant container; may be a
# no-op for plain channel @mentions depending on your app config.
SLACK_STREAM_STATUS=false

# --- Flow-B run limits (Slack → Claude) ---
# Real @mention work can take 30–60+ min, so there is NO blind wall-clock cap.
# An inactivity watchdog stops a run only when it produces NO output for
# FLOW_B_IDLE_TIMEOUT seconds (a genuinely stuck process); the timer resets on
# every stream event, so an actively-working session is never cut off.
# FLOW_B_MAX_RUNTIME is a generous hard backstop against a runaway that never
# stops emitting. Raise the idle value if you run very long silent tools (big
# builds/test suites). Defaults: 1200 (20 min) idle, 14400 (4 h) backstop.
FLOW_B_IDLE_TIMEOUT=1200
FLOW_B_MAX_RUNTIME=14400

# --- GitHub (optional) ---
# Fine-grained PAT used by `gh` and `git push` inside the container.
# Required only if you want the /process workflow to open PRs and read review
# comments. Leave unset to run without GitHub integration.
# Setup guide: docs/github-setup.md
GITHUB_TOKEN=github_pat_...

# --- Access control (optional) ---
# Leave SECURITY_ENABLED unset or "false" to skip all access checks; the other
# SECURITY_* vars can then be omitted entirely.
SECURITY_ENABLED=false
# Strict mode: empty allowlist = deny all. Flexible mode (false): empty = allow all.
SECURITY_STRICT_MODE=false
# Comma-separated Slack user IDs allowed to use the bot (e.g. U0123ABC,U0456DEF)
SECURITY_ALLOWED_USERS=
# Comma-separated Slack channel IDs the bot will respond in (e.g. C0123ABC,C0456DEF)
SECURITY_ALLOWED_CHANNELS=
# Comma-separated user IDs that bypass the channel allowlist
SECURITY_ADMIN_USERS=
# Message posted back to unauthorized users
SECURITY_REJECTION_MESSAGE=You are not authorized to use this bot.
# Emit a warning log line on each denial
SECURITY_LOG_UNAUTHORIZED=true
